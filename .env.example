# ──────────────────────────────────────────────
# Mediverse — Career OS for Medicine
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# ─── Database (PostgreSQL + pgvector) ─────────
DATABASE_URL=postgresql://user:password@localhost:5432/mediverse

# ─── Redis (BullMQ queues) ────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI (Anthropic Claude) ────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Medical Data APIs ────────────────────────
NCBI_API_KEY=your_ncbi_api_key
YOUTUBE_API_KEY=your_youtube_api_key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# ─── S3-Compatible Storage ────────────────────
S3_BUCKET=mediverse-assets
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key

# ─── SMS Provider (OTP Auth) ──────────────────
SMS_PROVIDER_API_KEY=your_sms_api_key

# ─── Session Signing (required, no default) ───
# Generate with: openssl rand -base64 48
JWT_SECRET=your_long_random_secret_key

# ─── Google OAuth 2.0 ────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# ─── Payments (scaffold only — not activated) ─
RAZORPAY_KEY=rzp_test_xxxxx
