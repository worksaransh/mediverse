{
  "name": "mediverse",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @mediverse/db db:generate",
    "db:migrate": "pnpm --filter @mediverse/db db:migrate",
    "db:push": "pnpm --filter @mediverse/db db:push",
    "db:seed": "pnpm --filter @mediverse/db db:seed",
    "db:studio": "pnpm --filter @mediverse/db db:studio",
    "pipeline:pharm": "pnpm --filter @mediverse/mcq-pipeline pipeline"
  },
  "devDependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "prettier": "^3.4.0",
    "supabase": "^2.109.0",
    "turbo": "^2.4.0"
  }
}
